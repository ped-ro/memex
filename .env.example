# memex — Environment Config
# Copy this file to .env and fill in your values
# Never commit .env to git

# ── Vault ──────────────────────────────────────────────────────────────────
# Absolute path to your notes directory (Obsidian, Markdown, etc.)
VAULT_PATH=/path/to/your/obsidian/vault

# ── PostgreSQL ─────────────────────────────────────────────────────────────
PGDATABASE=obsidian
PGUSER=postgres
PGPASSWORD=changeme

# ── MCP Server ─────────────────────────────────────────────────────────────
# Generate a strong random key: openssl rand -hex 32
MCP_API_KEY=changeme

# ── Sync ───────────────────────────────────────────────────────────────────
# Sync interval in seconds (default: 900 = 15 minutes)
SYNC_INTERVAL_SEC=900

# ── OpenAI Embeddings (optional) ──────────────────────────────────────────
# Only needed if using docker-compose.openai.yml override
# Default stack uses local mxbai-embed-large-v1 — no API key required
# OPENAI_API_KEY=sk-...
