# Vault Search Stack — Environment Config
# Copy this file to .env and fill in your values
# Never commit .env to git

# ── Vault ──────────────────────────────────────────────────────────────────
# Absolute path to your notes directory (Obsidian, Markdown, etc.)
VAULT_PATH=/path/to/your/obsidian/vault

# ── PostgreSQL ─────────────────────────────────────────────────────────────
PGDATABASE=obsidian
PGUSER=postgres
PGPASSWORD=changeme

# ── MCP Server ─────────────────────────────────────────────────────────────
# Generate a strong random key: openssl rand -hex 32
MCP_API_KEY=changeme

# ── Sync ───────────────────────────────────────────────────────────────────
# Sync interval in seconds (default: 900 = 15 minutes)
SYNC_INTERVAL_SEC=900
